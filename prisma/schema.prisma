// Prisma schema for Hermes Agent Platform

generator client {
  provider = \"prisma-client-js\"
}

datasource db {
  provider = \"sqlite\"
  url      = env(\"DATABASE_URL\")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  image         String?
  role          String    @default(\"user\") // user, admin, superadmin
  provider      String    @default(\"credentials\") // credentials, github, google
  providerId    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  accounts      Account[]
  sessions      Session[]
  workspaces    Workspace[]
  apiKeys       ApiKey[]
  subscriptions Subscription[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Workspace {
  id          String   @id @default(cuid())
  name        String
  description String?
  shareId     String   @unique @default(cuid())
  isPublic    Boolean  @default(false)
  
  // Settings
  settings    String   @default(\"{}\") // JSON settings
  
  // Subscription tier
  plan        String   @default(\"free\") // free, starter, pro, enterprise
  
  // Limits
  maxMessages Int      @default(100)
  maxAgents   Int      @default(3)
  
  // Ownership
  userId      String
  teamId      String?
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  team        Team?    @relation(fields: [teamId], references: [id])
  conversations Conversation[]
  agents      Agent[]
}

model Conversation {
  id          String   @id @default(cuid())
  title       String   @default(\"New Conversation\")
  workspaceId String
  
  // Message count for quick stats
  messageCount Int     @default(0)
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  messages    Message[]
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String   // system, user, assistant
  content        String
  model          String?
  tokens         Int?
  
  // Metadata
  metadata       String?  @default(\"{}\") // JSON for additional data
  
  createdAt      DateTime @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Agent {
  id          String   @id @default(cuid())
  name        String
  description String?
  persona     String   @default(\"You are a helpful AI assistant.\")
  
  // Configuration
  config      String   @default(\"{}\") // JSON config
  
  // Provider settings
  provider    String   @default(\"openai\") // openai, anthropic,Nous, custom
  modelName   String   @default(\"gpt-4\")
  
  // Tools enabled
  tools       String   @default(\"[]\") // JSON array of tool names
  
  // Workspace
  workspaceId String
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id          String   @id @default(cuid())
  name        String
  keyHash     String   // Hashed version of the key
  keyPrefix   String   // First 8 chars for display
  provider    String   // openai, anthropic,Nous, etc.
  
  // Usage tracking
  usedBytes   Int      @default(0)
  usedCount   Int      @default(0)
  
  // Active status
  isActive    Boolean  @default(true)
  
  // Ownership
  userId      String
  createdAt   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([keyHash])
}

model Subscription {
  id              String   @id @default(cuid())
  userId          String
  plan            String   // free, starter, pro, enterprise
  status          String   // active, canceled, past_due, trialing
  
  // Billing
  stripeCustomerId String?
  stripeSubscriptionId String?
  currentPeriodEnd DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Team {
  id          String   @id @default(cuid())
  name        String
  description String?
  plan        String   @default(\"starter\")
  
  // Members
  ownerId     String
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspaces  Workspace[]
  members     TeamMember[]
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  role      String   @default(\"member\") // owner, admin, member
  
  createdAt DateTime @default(now())

  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model Plugin {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  version     String   @default(\"1.0.0\")
  
  // Plugin type
  type        String   // tool, persona, integration
  
  // Code or config
  code        String?  // Plugin code
  config      String   @default(\"{}\") // Plugin configuration
  
  // Enabled by default
  isEnabled   Boolean  @default(false)
  
  // Who can use this plugin
  visibility  String   @default(\"private\") // private, team, public
  
  // Ownership
  userId      String?
  teamId      String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UsageLog {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String?
  
  // Usage details
  type        String   // messages, tokens, storage, api_calls
  amount      Int
  provider    String?
  
  // Cost tracking
  costCents   Int      @default(0)
  
  createdAt   DateTime @default(now())
}