[TEMPLATE]
# Hermes Agent Microservice Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED VARIABLES
# =============================================================================

# API Server Key - Used to authenticate requests to the Hermes API
# Generate a secure key: openssl rand -hex 32
# NOTE: Set HERMES_AGENT_API_KEY in your SAHJONY platform .env.local
API_SERVER_KEY=generate-a-secure-random-string-here

# Anthropic API Key - For AI model access
ANTHROPIC_API_KEY=sk-ant-xxxxx

# =============================================================================
# OPTIONAL VARIABLES
# =============================================================================

# OpenAI API Key (alternative to Anthropic)
# OPENAI_API_KEY=sk-xxxxx

# Server Configuration
API_SERVER_ENABLED=true
API_SERVER_PORT=8642
API_SERVER_HOST=0.0.0.0

# Docker container user/group IDs
HERMES_UID=10000
HERMES_GID=10000

# Optional: Logging
# HERMES_LOG_LEVEL=INFO

# =============================================================================
# SAHJONY PLATFORM CONNECTION
# =============================================================================
# In your SAHJONY .env.local, also set:
# HERMES_AGENT_URL=http://your-hermes-server:8642
# HERMES_AGENT_API_KEY=<same value as API_SERVER_KEY>
